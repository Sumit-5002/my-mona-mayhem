---
export const prerender = false;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="View the full match history and leaderboard for the Mona Mayhem GitHub Contribution Battle Arena." />
		<title>Leaderboard & Match History | Mona Mayhem</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
		<style>
			:root {
				--bg-color: #0a0a1a;
				--accent-green: #5fed83;
				--accent-purple: #8a2be2;
				--accent-yellow: #ffff00;
				--accent-red: #ff3333;
				--text-color: #ffffff;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }

			body {
				font-family: 'Press Start 2P', cursive;
				background-color: var(--bg-color);
				color: var(--text-color);
				min-height: 100vh;
				padding: 2rem 1rem;
				position: relative;
				overflow-x: hidden;
			}

			/* CRT Scanline */
			body::after {
				content: " ";
				display: block;
				position: fixed;
				top: 0; left: 0; bottom: 0; right: 0;
				background: linear-gradient(to bottom, rgba(18,16,16,0) 50%, rgba(0,0,0,0.2) 50%);
				background-size: 100% 4px;
				z-index: 50;
				pointer-events: none;
			}

			main {
				max-width: 1100px;
				margin: 0 auto;
				position: relative;
				z-index: 10;
			}

			header {
				text-align: center;
				margin-bottom: 3rem;
			}

			@keyframes neon-pulse {
				0%, 100% { text-shadow: 0 0 10px var(--accent-green), 0 0 20px var(--accent-green), 0 0 40px var(--accent-green); }
				50% { text-shadow: 0 0 5px var(--accent-green), 0 0 10px var(--accent-green); }
			}

			h1 {
				font-size: 1.8rem;
				color: var(--accent-green);
				animation: neon-pulse 1.5s infinite alternate;
				margin-bottom: 1rem;
			}

			header p {
				font-size: 0.65rem;
				color: var(--accent-purple);
				text-shadow: 0 0 5px var(--accent-purple);
				margin-bottom: 0.5rem;
			}

			.nav-link {
				display: inline-block;
				margin-top: 1rem;
				padding: 0.6rem 1.2rem;
				border: 2px solid var(--accent-green);
				color: var(--accent-green);
				text-decoration: none;
				font-size: 0.55rem;
				transition: all 0.2s;
			}

			.nav-link:hover {
				background: var(--accent-green);
				color: #000;
				box-shadow: 0 0 15px var(--accent-green);
			}

			/* Stats Bar */
			.stats-bar {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
				margin-bottom: 3rem;
			}

			.stat-card {
				background: rgba(20, 20, 40, 0.9);
				border: 2px solid var(--accent-purple);
				padding: 1.5rem 1rem;
				text-align: center;
				box-shadow: 0 0 15px rgba(138, 43, 226, 0.3);
				position: relative;
				overflow: hidden;
			}

			@keyframes shimmer {
				0% { background-position: -200% 0; }
				100% { background-position: 200% 0; }
			}

			.stat-card::before {
				content: "";
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
				background-size: 200% 100%;
				animation: shimmer 3s infinite linear;
				pointer-events: none;
			}

			.stat-card .stat-label {
				font-size: 0.5rem;
				color: #aaa;
				margin-bottom: 1rem;
				text-transform: uppercase;
			}

			.stat-card .stat-value {
				font-size: 1.8rem;
				color: var(--accent-green);
				text-shadow: 0 0 10px var(--accent-green);
			}

			/* Leaderboard */
			.section-title {
				font-size: 0.9rem;
				color: var(--accent-yellow);
				text-shadow: 0 0 10px var(--accent-yellow);
				margin-bottom: 1.5rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid var(--accent-yellow);
			}

			.leaderboard-section {
				margin-bottom: 3rem;
			}

			.leaderboard-table {
				width: 100%;
				border-collapse: collapse;
			}

			.leaderboard-table th {
				background: rgba(138, 43, 226, 0.3);
				color: var(--accent-purple);
				padding: 1rem 0.8rem;
				text-align: left;
				font-size: 0.5rem;
				text-transform: uppercase;
				border-bottom: 2px solid var(--accent-purple);
			}

			.leaderboard-table td {
				padding: 1rem 0.8rem;
				font-size: 0.55rem;
				border-bottom: 1px solid #222;
			}

			.leaderboard-table tr:hover td {
				background: rgba(95, 237, 131, 0.05);
			}

			.rank-1 td { color: var(--accent-yellow); text-shadow: 0 0 5px var(--accent-yellow); }
			.rank-2 td { color: #c0c0c0; }
			.rank-3 td { color: #cd7f32; }

			.rank-badge {
				display: inline-block;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				text-align: center;
				line-height: 28px;
				font-size: 0.55rem;
				margin-right: 0.5rem;
			}

			.rank-1 .rank-badge { background: var(--accent-yellow); color: #000; }
			.rank-2 .rank-badge { background: #c0c0c0; color: #000; }
			.rank-3 .rank-badge { background: #cd7f32; color: #000; }
			.rank-other .rank-badge { background: #333; color: #aaa; }

			.win-rate-bar {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.win-rate-fill {
				height: 8px;
				background: var(--accent-green);
				box-shadow: 0 0 5px var(--accent-green);
				min-width: 2px;
				transition: width 0.5s ease;
			}

			.win-rate-bg {
				width: 80px;
				height: 8px;
				background: #222;
				overflow: hidden;
			}

			/* Match History */
			.history-section {
				margin-bottom: 3rem;
			}

			.history-controls {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
				gap: 1rem;
			}

			.filter-tabs {
				display: flex;
				gap: 0.5rem;
			}

			.filter-tab {
				padding: 0.5rem 1rem;
				background: transparent;
				border: 2px solid #444;
				color: #aaa;
				font-family: 'Press Start 2P', cursive;
				font-size: 0.5rem;
				cursor: pointer;
				transition: all 0.2s;
			}

			.filter-tab.active, .filter-tab:hover {
				border-color: var(--accent-green);
				color: var(--accent-green);
				box-shadow: 0 0 8px var(--accent-green);
			}

			#clearAllBtn {
				padding: 0.6rem 1rem;
				background: transparent;
				border: 2px solid var(--accent-red);
				color: var(--accent-red);
				font-family: 'Press Start 2P', cursive;
				font-size: 0.5rem;
				cursor: pointer;
				transition: all 0.2s;
			}

			#clearAllBtn:hover {
				background: var(--accent-red);
				color: #000;
				box-shadow: 0 0 10px var(--accent-red);
			}

			.match-list {
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
			}

			@keyframes slide-in {
				from { opacity: 0; transform: translateX(-20px); }
				to { opacity: 1; transform: translateX(0); }
			}

			.match-item {
				display: grid;
				grid-template-columns: 60px 1fr auto 1fr 120px;
				align-items: center;
				gap: 1rem;
				padding: 1rem 1.5rem;
				background: rgba(10, 10, 30, 0.9);
				border: 1px solid #333;
				border-left: 4px solid var(--accent-green);
				animation: slide-in 0.3s ease forwards;
				transition: border-color 0.2s;
			}

			.match-item:hover {
				border-left-color: var(--accent-purple);
				box-shadow: 0 0 15px rgba(138, 43, 226, 0.2);
			}

			.match-number {
				font-size: 0.5rem;
				color: #555;
				text-align: center;
			}

			.match-player {
				font-size: 0.55rem;
			}

			.match-player.winner {
				color: var(--accent-green);
				text-shadow: 0 0 5px var(--accent-green);
			}

			.match-player.loser {
				color: #666;
			}

			.match-vs {
				font-size: 0.7rem;
				color: var(--accent-purple);
				text-align: center;
				text-shadow: 0 0 5px var(--accent-purple);
			}

			.match-result {
				font-size: 0.5rem;
				text-align: right;
			}

			.result-win { color: var(--accent-green); }
			.result-tie { color: var(--accent-yellow); }

			.match-time {
				font-size: 0.45rem;
				color: #555;
				text-align: right;
			}

			.empty-state {
				text-align: center;
				padding: 4rem 2rem;
				color: #444;
				font-size: 0.7rem;
				line-height: 2;
			}

			.empty-state .empty-icon {
				font-size: 3rem;
				display: block;
				margin-bottom: 1.5rem;
			}

			#noHistoryMsg {
				display: none;
			}

			@media (max-width: 768px) {
				h1 { font-size: 1.1rem; }
				.stats-bar { grid-template-columns: repeat(2, 1fr); }
				.match-item { grid-template-columns: 1fr; gap: 0.5rem; }
				.match-vs { text-align: left; }
				.match-result, .match-time { text-align: left; }
				.leaderboard-table th:nth-child(4),
				.leaderboard-table td:nth-child(4) { display: none; }
			}
		</style>
	</head>
	<body>
		<main>
			<header>
				<h1>🏆 ARENA LEADERBOARD</h1>
				<p>GitHub Contribution Battle Records</p>
				<a href="/" class="nav-link">← BACK TO BATTLE</a>
			</header>

			<!-- Stats Bar -->
			<section class="stats-bar" id="statsBar">
				<div class="stat-card">
					<div class="stat-label">Total Battles</div>
					<div class="stat-value" id="totalBattles">0</div>
				</div>
				<div class="stat-card">
					<div class="stat-label">Unique Players</div>
					<div class="stat-value" id="uniquePlayers">0</div>
				</div>
				<div class="stat-card">
					<div class="stat-label">Ties</div>
					<div class="stat-value" id="totalTies">0</div>
				</div>
				<div class="stat-card">
					<div class="stat-label">Top Warrior</div>
					<div class="stat-value" id="topWarrior" style="font-size: 0.65rem; word-break: break-all;">-</div>
				</div>
			</section>

			<!-- Leaderboard -->
			<section class="leaderboard-section">
				<h2 class="section-title">👑 WIN LEADERBOARD</h2>
				<div id="leaderboardContainer">
					<div class="empty-state" id="noLeaderboardMsg">
						<span class="empty-icon">🎮</span>
						No battles recorded yet.<br>Go fight someone!
					</div>
					<table class="leaderboard-table" id="leaderboardTable" style="display:none">
						<thead>
							<tr>
								<th>Rank</th>
								<th>Player</th>
								<th>Wins</th>
								<th>Battles</th>
								<th>Win Rate</th>
							</tr>
						</thead>
						<tbody id="leaderboardBody"></tbody>
					</table>
				</div>
			</section>

			<!-- Match History -->
			<section class="history-section">
				<h2 class="section-title">📜 MATCH HISTORY</h2>
				<div class="history-controls">
					<div class="filter-tabs">
						<button class="filter-tab active" id="filterAll" data-filter="all">ALL</button>
						<button class="filter-tab" id="filterWins" data-filter="wins">WINS</button>
						<button class="filter-tab" id="filterTies" data-filter="ties">TIES</button>
					</div>
					<button id="clearAllBtn">🗑 CLEAR ALL</button>
				</div>

				<div class="match-list" id="matchList">
					<div class="empty-state" id="noHistoryMsg">
						<span class="empty-icon">⚔️</span>
						No match history found.<br>Start a battle to record your first match!
					</div>
				</div>
			</section>
		</main>

		<script>
			interface MatchRecord {
				p1: string;
				p2: string;
				winner: string;
				p1Total?: number;
				p2Total?: number;
				time: string;
				date?: string;
				isTie?: boolean;
			}

			function getHistory(): MatchRecord[] {
				try {
					return JSON.parse(localStorage.getItem('battle_history') || '[]');
				} catch {
					return [];
				}
			}

			function computeStats(history: MatchRecord[]) {
				// Total battles
				(document.getElementById('totalBattles') as HTMLElement).textContent = String(history.length);

				// Unique players
				const players = new Set<string>();
				history.forEach(h => { players.add(h.p1.toLowerCase()); players.add(h.p2.toLowerCase()); });
				(document.getElementById('uniquePlayers') as HTMLElement).textContent = String(players.size);

				// Ties
				const ties = history.filter(h => h.isTie || h.winner === "It's a tie! 🤝" || h.winner === '').length;
				(document.getElementById('totalTies') as HTMLElement).textContent = String(ties);
			}

			function buildLeaderboard(history: MatchRecord[]) {
				const wins: Record<string, number> = {};
				const battles: Record<string, number> = {};

				history.forEach(h => {
					const p1 = h.p1.toLowerCase();
					const p2 = h.p2.toLowerCase();
					battles[p1] = (battles[p1] || 0) + 1;
					battles[p2] = (battles[p2] || 0) + 1;

					const isTie = h.isTie || h.winner === "It's a tie! 🤝" || !h.winner;
					if (!isTie) {
						const winner = h.winner.replace("It's a tie! 🤝", '').toLowerCase().trim();
						wins[winner] = (wins[winner] || 0) + 1;
					}
				});

				const allPlayers = Object.keys(battles).sort((a, b) => (wins[b] || 0) - (wins[a] || 0));

				if (allPlayers.length === 0) {
					(document.getElementById('noLeaderboardMsg') as HTMLElement).style.display = 'block';
					(document.getElementById('leaderboardTable') as HTMLElement).style.display = 'none';
					(document.getElementById('topWarrior') as HTMLElement).textContent = '-';
					return;
				}

				(document.getElementById('noLeaderboardMsg') as HTMLElement).style.display = 'none';
				(document.getElementById('leaderboardTable') as HTMLElement).style.display = 'table';
				(document.getElementById('topWarrior') as HTMLElement).textContent = allPlayers[0].toUpperCase();

				const tbody = document.getElementById('leaderboardBody') as HTMLElement;
				tbody.innerHTML = allPlayers.map((player, i) => {
					const rank = i + 1;
					const w = wins[player] || 0;
					const b = battles[player] || 0;
					const rate = b > 0 ? Math.round((w / b) * 100) : 0;
					const rankClass = rank <= 3 ? `rank-${rank}` : 'rank-other';
					const medal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
					return `<tr class="${rankClass}">
						<td><span class="rank-badge">${medal}</span></td>
						<td>${player.toUpperCase()}</td>
						<td>${w}</td>
						<td>${b}</td>
						<td>
							<div class="win-rate-bar">
								<div class="win-rate-bg"><div class="win-rate-fill" style="width:${rate}%"></div></div>
								<span>${rate}%</span>
							</div>
						</td>
					</tr>`;
				}).join('');
			}

			function renderMatches(history: MatchRecord[], filter: string = 'all') {
				const list = document.getElementById('matchList') as HTMLElement;
				const noMsg = document.getElementById('noHistoryMsg') as HTMLElement;

				let filtered = [...history];
				if (filter === 'wins') {
					filtered = history.filter(h => !h.isTie && h.winner && h.winner !== "It's a tie! 🤝");
				} else if (filter === 'ties') {
					filtered = history.filter(h => h.isTie || h.winner === "It's a tie! 🤝");
				}

				if (filtered.length === 0) {
					noMsg.style.display = 'block';
					list.innerHTML = '';
					list.appendChild(noMsg);
					return;
				}

				noMsg.style.display = 'none';
				list.innerHTML = filtered.map((h, i) => {
					const isTie = h.isTie || h.winner === "It's a tie! 🤝";
					const winnerName = isTie ? '' : h.winner.replace('🏆 ', '').replace(' wins!', '').toLowerCase().trim();
					const p1IsWinner = !isTie && winnerName === h.p1.toLowerCase();
					const p2IsWinner = !isTie && winnerName === h.p2.toLowerCase();

					return `<div class="match-item" style="animation-delay:${i * 0.05}s">
						<div class="match-number">#${history.length - history.indexOf(h)}</div>
						<div class="match-player ${p1IsWinner ? 'winner' : 'loser'}">${h.p1.toUpperCase()} ${p1IsWinner ? '🏆' : ''}</div>
						<div class="match-vs">VS</div>
						<div class="match-player ${p2IsWinner ? 'winner' : 'loser'}">${h.p2.toUpperCase()} ${p2IsWinner ? '🏆' : ''}</div>
						<div>
							<div class="match-result ${isTie ? 'result-tie' : 'result-win'}">${isTie ? '🤝 TIE' : `🏆 ${winnerName.toUpperCase()}`}</div>
							<div class="match-time">${h.time || ''}</div>
						</div>
					</div>`;
				}).join('');
			}

			// Init
			let currentFilter = 'all';
			const history = getHistory();
			computeStats(history);
			buildLeaderboard(history);
			renderMatches(history, currentFilter);

			// Filter tabs
			document.querySelectorAll('.filter-tab').forEach(tab => {
				tab.addEventListener('click', () => {
					document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
					tab.classList.add('active');
					currentFilter = (tab as HTMLElement).dataset.filter || 'all';
					renderMatches(getHistory(), currentFilter);
				});
			});

			// Clear all
			document.getElementById('clearAllBtn')!.addEventListener('click', () => {
				if (confirm('Clear ALL battle history? This cannot be undone.')) {
					localStorage.removeItem('battle_history');
					computeStats([]);
					buildLeaderboard([]);
					renderMatches([], currentFilter);
				}
			});
		</script>
	</body>
</html>
