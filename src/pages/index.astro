---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
		<style>
    :root {
        --bg-color: #0a0a1a;
        --accent-green: #5fed83;
        --accent-purple: #8a2be2;
        --text-color: #ffffff;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Press Start 2P', cursive;
        background-color: var(--bg-color);
        color: var(--text-color);
        min-height: 100vh;
        padding: 2rem 1rem;
        position: relative;
        overflow-x: hidden;
    }

    /* CRT Scanline Effect */
    body::after {
        content: " ";
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: linear-gradient(
            to bottom,
            rgba(18, 16, 16, 0) 50%,
            rgba(0, 0, 0, 0.25) 50%
        );
        background-size: 100% 4px;
        z-index: 50;
        pointer-events: none;
    }

    header {
        text-align: center;
        margin-bottom: 3rem;
    }

    @keyframes neon-pulse {
        0%, 100% { text-shadow: 0 0 10px var(--accent-green), 0 0 20px var(--accent-green), 0 0 40px var(--accent-green); }
        50% { text-shadow: 0 0 5px var(--accent-green), 0 0 10px var(--accent-green), 0 0 20px var(--accent-green); }
    }

    h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: var(--accent-green);
        animation: neon-pulse 1.5s infinite alternate;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    header p {
        font-size: 0.8rem;
        color: var(--accent-purple);
        line-height: 1.5;
        text-shadow: 0 0 5px var(--accent-purple);
    }

    main {
        max-width: 1000px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    @keyframes float-in {
        0% { transform: translateY(-20px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }

    .battle-input {
        display: flex;
        gap: 1.5rem;
        align-items: flex-end;
        flex-wrap: wrap;
        justify-content: center;
        background: rgba(20, 20, 40, 0.8);
        padding: 2rem;
        border: 2px solid var(--accent-purple);
        border-radius: 0;
        box-shadow: 0 0 15px rgba(138, 43, 226, 0.4);
        margin-bottom: 2rem;
        animation: float-in 0.5s ease-out forwards;
    }

    .player-input {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        flex: 1;
        min-width: 200px;
    }

    .player-input label {
        color: var(--accent-green);
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .player-input input {
        padding: 1rem;
        background: #000;
        border: 2px solid var(--accent-green);
        color: #fff;
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

    .player-input input:focus {
        outline: none;
        box-shadow: 0 0 15px var(--accent-green);
    }

    #battleBtn {
        padding: 1rem 2rem;
        background: transparent;
        color: var(--accent-green);
        border: 2px solid var(--accent-green);
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
        text-transform: uppercase;
    }

    #battleBtn:hover:not(:disabled) {
        background: var(--accent-green);
        color: #000;
        box-shadow: 0 0 20px var(--accent-green);
    }

    @keyframes pulse {
        0% { opacity: 0.6; }
        50% { opacity: 1; }
        100% { opacity: 0.6; }
    }

    #battleBtn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        animation: pulse 1.5s infinite;
        border-color: #666;
        color: #666;
    }

    .error-message {
        color: #ff3333;
        font-size: 0.7rem;
        margin-top: 1rem;
        width: 100%;
        text-align: center;
        text-shadow: 0 0 5px #ff3333;
    }

    .battle-results {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 2rem;
        margin-top: 2rem;
        align-items: start;
    }

    @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    .player-card {
        background: rgba(10, 10, 30, 0.9);
        border: 2px solid var(--accent-purple);
        padding: 2rem;
        box-shadow: 0 0 20px rgba(138, 43, 226, 0.2);
        position: relative;
        overflow: hidden;
    }

    .player-card::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
        background-size: 200% 100%;
        animation: shimmer 3s infinite linear;
        pointer-events: none;
    }

    .player-card h2 {
        color: var(--accent-green);
        margin-bottom: 1.5rem;
        font-size: 1.2rem;
        text-shadow: 0 0 5px var(--accent-green);
    }

    .stats {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .stat {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 0.75rem;
        border-bottom: 2px dashed #333;
    }

    .stat .label {
        color: #aaa;
        font-size: 0.6rem;
    }

    .stat .value {
        color: var(--accent-purple);
        font-size: 1rem;
        text-shadow: 0 0 5px var(--accent-purple);
    }

    .player-meta {
        color: #888;
        font-size: 0.6rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .contribution-graph {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 2px dashed #333;
    }

    .graph-title {
        font-size: 0.6rem;
        color: #aaa;
        margin-bottom: 1rem;
    }

    .weeks {
        display: flex;
        gap: 3px;
        overflow-x: auto;
        padding: 0.5rem 0;
        scrollbar-width: thin;
        scrollbar-color: var(--accent-purple) #111;
    }

    .week {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .day {
        width: 12px;
        height: 12px;
        border-radius: 0;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid #222;
    }

    .day:hover {
        transform: scale(1.5);
        z-index: 10;
        box-shadow: 0 0 10px currentColor;
    }

    /* GitHub contribution colors adapted for retro theme */
    .level-0 { background: #111; border-color: #222; }
    .level-1 { background: #196127; color: #196127; }
    .level-2 { background: #239a3b; color: #239a3b; }
    .level-3 { background: #7bc96f; color: #7bc96f; }
    .level-4 { background: #c6e48b; color: #c6e48b; }

    @keyframes badge-shift {
        0% { filter: hue-rotate(0deg); text-shadow: 0 0 10px #ff00ff; }
        50% { filter: hue-rotate(90deg); text-shadow: 0 0 20px #00ffff; }
        100% { filter: hue-rotate(0deg); text-shadow: 0 0 10px #ff00ff; }
    }

    .vs-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #fff;
        margin-top: 5rem;
        animation: badge-shift 3s infinite;
    }

    .hidden {
        display: none !important;
    }

    #newBattleContainer {
        text-align: center;
        margin-top: 3rem;
    }

    #newBattleBtn {
        padding: 1rem 2rem;
        background: var(--accent-purple);
        color: #000;
        border: none;
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
        text-transform: uppercase;
        box-shadow: 0 0 15px var(--accent-purple);
    }

    #newBattleBtn:hover {
        transform: scale(1.05);
        box-shadow: 0 0 25px var(--accent-purple);
    }

    @keyframes color-shift {
        0% { color: var(--accent-green); }
        50% { color: var(--accent-purple); }
        100% { color: var(--accent-green); }
    }

    .loading {
        text-align: center;
        font-size: 0.8rem;
        animation: color-shift 1s infinite;
        margin-top: 1rem;
    }

    @media (max-width: 1024px) {
        h1 { font-size: 1.2rem; }
        .battle-input { flex-direction: column; }
        .player-input { width: 100%; }
        #battleBtn { width: 100%; }
        .battle-results { grid-template-columns: 1fr; }
        .vs-badge { margin: 1rem 0; }
    }

    /* Focus Styles for Accessibility */
    input:focus-visible, button:focus-visible {
        outline: 3px solid var(--accent-green);
        outline-offset: 4px;
        box-shadow: 0 0 15px var(--accent-green);
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        75% { transform: translateX(10px); }
    }

    .shake {
        animation: shake 0.3s ease-in-out 0s 2;
        border-color: #ff3333 !important;
        box-shadow: 0 0 20px #ff3333 !important;
    }

    /* Refined Media Queries */
    @media (max-width: 1024px) {
        .battle-results {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
        .vs-badge {
            margin: 2rem 0;
            order: 0;
        }
    }


    /* Bonus Styles */
    #battleOverlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        color: var(--accent-green);
    }

    #countdownText {
        font-size: 5rem;
        text-shadow: 0 0 20px var(--accent-green);
        animation: pulse 1s infinite;
    }

    .history-section {
        margin-top: 5rem;
        padding: 2rem;
        background: rgba(20, 20, 40, 0.8);
        border: 2px solid var(--accent-purple);
    }

    .history-section h2 {
        font-size: 1rem;
        color: var(--accent-purple);
        margin-bottom: 2rem;
        text-align: center;
    }

    .history-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .history-item {
        display: flex;
        justify-content: space-between;
        padding: 1rem;
        background: #000;
        border-left: 4px solid var(--accent-green);
        font-size: 0.6rem;
    }

    .legend {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        font-size: 0.6rem;
        color: #aaa;
    }

    .legend-box {
        width: 12px;
        height: 12px;
    }

    .share-btn {
        margin-top: 2rem;
        padding: 0.8rem 1.5rem;
        background: transparent;
        color: var(--accent-green);
        border: 2px solid var(--accent-green);
        font-family: 'Press Start 2P', cursive;
        font-size: 0.6rem;
        cursor: pointer;
    }

    #muteBtn {
        position: fixed;
        top: 1rem;
        right: 1rem;
        background: transparent;
        border: 2px solid var(--accent-purple);
        color: var(--accent-purple);
        padding: 0.5rem;
        font-size: 0.6rem;
        cursor: pointer;
        z-index: 2000;
    }

</style>
	</head>
	<body>
        <button id="muteBtn">🔊 MUTE</button>
        <div id="battleOverlay" class="hidden">
            <div id="countdownText">3</div>
        </div>

		<header>
			<h1>⚔️ Mona Mayhem</h1>
			<p>The Ultimate GitHub Contribution Battle Arena</p>
		</header>

		<main>
			<section class="battle-input">
				<div class="player-input">
					<label for="player1">Player 1</label>
					<input type="text" id="player1" placeholder="Enter GitHub username" />
				</div>

				<button id="battleBtn">Battle!</button>

				<div class="player-input">
					<label for="player2">Player 2</label>
					<input type="text" id="player2" placeholder="Enter GitHub username" />
				</div>

				<div id="error" class="error-message"></div>
			</section>

			<section id="battleResults" class="battle-results hidden">
				<article class="player-card">
					<h2 id="player1Name"></h2>
					<div class="player-meta">
						<div id="player1DateRange"></div>
					</div>
					<div class="stats">
						<div class="stat">
							<span class="label">Total Contributions</span>
							<span class="value" id="player1Total"></span>
						</div>
					</div>
					<div class="contribution-graph">
						<div class="graph-title">Last Year</div>
						<div class="weeks" id="player1Graph"></div>
                        <div class="legend">
                            <span>Less</span>
                            <div class="legend-box level-0"></div>
                            <div class="legend-box level-1"></div>
                            <div class="legend-box level-2"></div>
                            <div class="legend-box level-3"></div>
                            <div class="legend-box level-4"></div>
                            <span>More</span>
                        </div>
					</div>
				</article>

				<div class="vs-badge">
					<div id="winnerText"></div>
                    <button id="shareBtn" class="share-btn hidden">📋 SHARE RESULTS</button>
				</div>

				<article class="player-card">
					<h2 id="player2Name"></h2>
					<div class="player-meta">
						<div id="player2DateRange"></div>
					</div>
					<div class="stats">
						<div class="stat">
							<span class="label">Total Contributions</span>
							<span class="value" id="player2Total"></span>
						</div>
					</div>
					<div class="contribution-graph">
						<div class="graph-title">Last Year</div>
						<div class="weeks" id="player2Graph"></div>
                        <div class="legend">
                            <span>Less</span>
                            <div class="legend-box level-0"></div>
                            <div class="legend-box level-1"></div>
                            <div class="legend-box level-2"></div>
                            <div class="legend-box level-3"></div>
                            <div class="legend-box level-4"></div>
                            <span>More</span>
                        </div>
					</div>
				</article>
			</section>

			<div id="newBattleContainer" class="hidden">
				<button id="newBattleBtn">⚔️ Battle Again!</button>
			</div>
		
            <section class="history-section">
                <h2>RECENT BATTLES</h2>
                <div id="historyList" class="history-list">
                    <p style="text-align: center; color: #666;">No battles recorded yet.</p>
                </div>
                <button id="clearHistory" class="share-btn" style="width: 100%; margin-top: 1rem;">CLEAR HISTORY</button>
            </section>
</main>

		<script>

            // Sound Manager
            class SoundManager {
                constructor() {
                    this.ctx = null;
                    this.muted = false;
                }
                init() { if (!this.ctx) this.ctx = new (window.AudioContext || window.webkitAudioContext)(); }
                play(type) {
                    if (this.muted || !this.ctx) return;
                    const osc = this.ctx.createOscillator();
                    const gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    if (type === 'start') {
                        osc.type = 'square';
                        osc.frequency.setValueAtTime(440, this.ctx.currentTime);
                        osc.frequency.exponentialRampToValueAtTime(880, this.ctx.currentTime + 0.1);
                        gain.gain.setValueAtTime(0.1, this.ctx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.1);
                        osc.start(); osc.stop(this.ctx.currentTime + 0.1);
                    } else if (type === 'success') {
                        osc.type = 'triangle';
                        osc.frequency.setValueAtTime(600, this.ctx.currentTime);
                        osc.frequency.exponentialRampToValueAtTime(1200, this.ctx.currentTime + 0.2);
                        gain.gain.setValueAtTime(0.1, this.ctx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.2);
                        osc.start(); osc.stop(this.ctx.currentTime + 0.2);
                    } else if (type === 'error') {
                        osc.type = 'sawtooth';
                        osc.frequency.setValueAtTime(200, this.ctx.currentTime);
                        osc.frequency.linearRampToValueAtTime(50, this.ctx.currentTime + 0.3);
                        gain.gain.setValueAtTime(0.1, this.ctx.currentTime);
                        gain.gain.linearRampToValueAtTime(0.01, this.ctx.currentTime + 0.3);
                        osc.start(); osc.stop(this.ctx.currentTime + 0.3);
                    }
                }
            }
            const sound = new SoundManager();

            // History Management
            function saveBattle(p1, p2, winner) {
                const history = JSON.parse(localStorage.getItem('battle_history') || '[]');
                history.unshift({ p1, p2, winner, time: new Date().toLocaleTimeString() });
                localStorage.setItem('battle_history', JSON.stringify(history.slice(0, 10)));
                renderHistory();
            }
            function renderHistory() {
                const history = JSON.parse(localStorage.getItem('battle_history') || '[]');
                const list = document.getElementById('historyList');
                if (history.length === 0) {
                    list.innerHTML = '<p style="text-align: center; color: #666;">No battles recorded yet.</p>';
                    return;
                }
                list.innerHTML = history.map(h => `<div class="history-item"><span>${h.p1} VS ${h.p2}</span><span>WINNER: ${h.winner}</span></div>`).join('');
            }
            renderHistory();

            document.getElementById('muteBtn').addEventListener('click', () => {
                sound.muted = !sound.muted;
                document.getElementById('muteBtn').textContent = sound.muted ? '🔇 UNMUTE' : '🔊 MUTE';
            });
            document.getElementById('clearHistory').addEventListener('click', () => {
                localStorage.removeItem('battle_history');
                renderHistory();
            });

            // Share Logic
            document.getElementById('shareBtn').addEventListener('click', () => {
                const text = `⚔️ MONA MAYHEM BATTLE ⚔️\n\n${document.getElementById('player1Name').textContent} (${document.getElementById('player1Total').textContent}) VS ${document.getElementById('player2Name').textContent} (${document.getElementById('player2Total').textContent})\n\n${document.getElementById('winnerText').textContent}`;
                navigator.clipboard.writeText(text);
                const btn = document.getElementById('shareBtn');
                const old = btn.textContent;
                btn.textContent = 'COPIED!';
                setTimeout(() => btn.textContent = old, 2000);
            });

			// TypeScript interfaces
			interface ContributionDay {
				date: string;
				count: number;
			}

			interface ContributionData {
				username: string;
				totalContributions: number;
				currentStreak: number;
				longestStreak: number;
				contributionsByDay: ContributionDay[];
				cached: boolean;
				error?: string;
			}

			// Get contribution level for coloring (0-4)
			function getContributionLevel(count: number): number {
				if (count === 0) return 0;
				if (count <= 5) return 1;
				if (count <= 15) return 2;
				if (count <= 30) return 3;
				return 4;
			}

			// Create contribution graph HTML
			function createContributionGraph(data: ContributionDay[]): string {
				if (!data || data.length === 0) {
					return '<div style="color: #999; font-size: 0.9rem;">No contribution data</div>';
				}

				// Group contributions by week
				const weeks: ContributionDay[][] = [];
				let currentWeek: ContributionDay[] = [];

				// Sort by date
				const sortedData = [...data].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

				// Group into weeks (Monday start)
				sortedData.forEach((day) => {
					const date = new Date(day.date);
					const dayOfWeek = (date.getDay() + 6) % 7; // 0 = Monday

					if (dayOfWeek === 0 && currentWeek.length > 0) {
						weeks.push(currentWeek);
						currentWeek = [];
					}
					currentWeek.push(day);
				});

				if (currentWeek.length > 0) {
					weeks.push(currentWeek);
				}

				// Create HTML for weeks (last 53 weeks)
				let html = '<div class="weeks">';
				weeks.slice(-53).forEach((week) => {
					html += '<div class="week">';
					// Pad week to 7 days
					for (let i = 0; i < 7; i++) {
						const day = week[i];
						if (day) {
							const level = getContributionLevel(day.count);
							html += `<div class="day level-${level}" title="${day.date}: ${day.count} contributions"></div>`;
						} else {
							html += '<div class="day level-0"></div>';
						}
					}
					html += '</div>';
				});
				html += '</div>';

				return html;
			}

			// Format date range
			function formatDateRange(data: ContributionDay[]): string {
				if (!data || data.length === 0) return '';
				const sortedData = [...data].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
				const firstDate = new Date(sortedData[0].date);
				const lastDate = new Date(sortedData[sortedData.length - 1].date);
				return `${firstDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} – ${lastDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;
			}

			const player1Input = document.getElementById('player1') as HTMLInputElement;
			const player2Input = document.getElementById('player2') as HTMLInputElement;
			const battleBtn = document.getElementById('battleBtn') as HTMLButtonElement;
			const errorDiv = document.getElementById('error') as HTMLDivElement;
			const resultsSection = document.getElementById('battleResults') as HTMLDivElement;
			const newBattleContainer = document.getElementById('newBattleContainer') as HTMLDivElement;
			const newBattleBtn = document.getElementById('newBattleBtn') as HTMLButtonElement;

			
            battleBtn.addEventListener('click', async () => {
                const player1 = player1Input.value.trim();
                const player2 = player2Input.value.trim();
                
                sound.init();

                // Validate inputs
                errorDiv.textContent = '';
                const inputContainer = document.querySelector('.battle-input');
                inputContainer.classList.remove('shake');

                if (!player1 || !player2) {
                    errorDiv.textContent = 'MISSING DATA - ENTER BOTH USERNAMES';
                    inputContainer.classList.add('shake');
                    sound.play('error');
                    return;
                }

                if (player1 === player2) {
                    errorDiv.textContent = 'DUPLICATE PLAYERS - USERS MUST BE UNIQUE';
                    inputContainer.classList.add('shake');
                    sound.play('error');
                    return;
                }

                sound.play('start');

                // Countdown Sequence
                const overlay = document.getElementById('battleOverlay');
                const cdText = document.getElementById('countdownText');
                overlay.classList.remove('hidden');
                
                for (let i = 3; i > 0; i--) {
                    cdText.textContent = i;
                    sound.play('start');
                    await new Promise(r => setTimeout(r, 800));
                }
                cdText.textContent = 'FIGHT!';
                sound.play('success');
                await new Promise(r => setTimeout(r, 500));
                overlay.classList.add('hidden');

                // Show loading state
                battleBtn.disabled = true;
                battleBtn.textContent = 'BATTLING...';


				try {
					// Fetch both players' data in parallel
					const [data1, data2] = await Promise.all([
						fetch(`/api/contributions/${encodeURIComponent(player1)}`).then(r => r.json() as Promise<ContributionData>),
						fetch(`/api/contributions/${encodeURIComponent(player2)}`).then(r => r.json() as Promise<ContributionData>),
					]);

					// Check for errors
					if (data1.error) {
						errorDiv.textContent = `Error fetching ${player1}: ${data1.error}`;
						battleBtn.disabled = false;
						battleBtn.textContent = 'Battle!';
						return;
					}
					if (data2.error) {
						errorDiv.textContent = `Error fetching ${player2}: ${data2.error}`;
						battleBtn.disabled = false;
						battleBtn.textContent = 'Battle!';
						return;
					}

					// Populate results
					document.getElementById('player1Name')!.textContent = data1.username;
					document.getElementById('player1Total')!.textContent = data1.totalContributions.toLocaleString();
					document.getElementById('player1DateRange')!.textContent = formatDateRange(data1.contributionsByDay);
					document.getElementById('player1Graph')!.innerHTML = createContributionGraph(data1.contributionsByDay);
                    document.getElementById('player1Streak')!.textContent = data1.longestStreak + ' DAYS';

					document.getElementById('player2Name')!.textContent = data2.username;
					document.getElementById('player2Total')!.textContent = data2.totalContributions.toLocaleString();
					document.getElementById('player2DateRange')!.textContent = formatDateRange(data2.contributionsByDay);
					document.getElementById('player2Graph')!.innerHTML = createContributionGraph(data2.contributionsByDay);
                    document.getElementById('player2Streak')!.textContent = data2.longestStreak + ' DAYS';

					// Determine winner
					let winner;
					if (data1.totalContributions > data2.totalContributions) {
						winner = `🏆 ${data1.username} wins!`;
					} else if (data2.totalContributions > data1.totalContributions) {
						winner = `🏆 ${data2.username} wins!`;
					} else {
						winner = "It's a tie! 🤝";
					}

					document.getElementById('winnerText')!.textContent = winner;
                    saveBattle(data1.username, data2.username, winner.replace('🏆 ', '').replace(' wins!', ''));
                    document.getElementById('shareBtn').classList.remove('hidden');
                    sound.play('success');


					// Show results
					resultsSection.classList.remove('hidden');
					newBattleContainer.classList.remove('hidden');
				} catch (err) {
					const errorMsg = err instanceof Error ? err.message : 'Unknown error';
					errorDiv.textContent = `Error: ${errorMsg}`;
				} finally {
					battleBtn.disabled = false;
					battleBtn.textContent = 'Battle!';
				}
			});

			newBattleBtn.addEventListener('click', () => {
				player1Input.value = '';
				player2Input.value = '';
				errorDiv.textContent = '';
				resultsSection.classList.add('hidden');
				newBattleContainer.classList.add('hidden');
			});

			// Allow Enter key to trigger battle
			[player1Input, player2Input].forEach((input) => {
				input.addEventListener('keypress', (e: KeyboardEvent) => {
					if (e.key === 'Enter') battleBtn.click();
				});
			});
		</script>
	</body>
</html>
